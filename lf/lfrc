# Custom command to pick images with sxiv
cmd sxiv_pick ${{
    # Find all image files in the current directory
    # Adjust the extensions if you need more (png, jpg, etc.)
    files=$(find . -maxdepth 1 -type f -iregex '.*\(jpg\|jpeg\|png\|gif\|bmp\|webp\)')
    
    if [ -n "$files" ]; then
        # Open sxiv in thumbnail mode (-t) 
        # -o tells sxiv to write the paths of selected files to stdout on exit
        selected=$(echo "$files" | sxiv -t -o)
        
        if [ -n "$selected" ]; then
            # Clear existing selection in lf
            lf -remote "send $id unselect"
            
            # Loop through the sxiv output and select them in lf
            echo "$selected" | while read -r line; do
                # Get the absolute path
                abs_path=$(realpath "$line")
                lf -remote "send $id select \"$abs_path\""
            done
        fi
    fi
}}

